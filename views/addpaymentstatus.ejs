<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <%- include('partials/head') %>
    <title>Add Payment Status | IOTECH Solutions</title>
</head>
<body>
    <%- include('partials/header') %>

    <main class="main-content">
        <div class="form-container">
            <h1 class="page-title text-center">Add Payment Status</h1>
            <p class="page-subtitle text-center">Final step: initialize project financials.</p>

            <div class="glass-card">
                <% if (locals.errors) { %>
                    <div class="form-error">
                        <ul>
                            <% errors.forEach(function(error) { %>
                                <li><%= error.msg %></li>
                            <% }); %>
                        </ul>
                    </div>
                <% } %>

                <form action="/projects/new/addpaymentstatus/<%= project_id %>" method="POST">
                    <input type="hidden" name="project_id" value="<%= project_id %>">

                    <div class="form-group">
                        <label class="form-label">First Installment (₹)</label>
                        <input type="number" name="first_installment" class="form-input" step="0.01" min="0" placeholder="0.00">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Second Installment (₹)</label>
                        <input type="number" name="second_installment" class="form-input" step="0.01" min="0" placeholder="0.00">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Total Fees (₹)</label>
                        <input type="number" name="total" class="form-input" step="0.01" required min="1" placeholder="Enter total fee amount">
                    </div>

                    <button type="submit" class="btn btn--primary btn--block btn--lg mt-24">Complete Setup ✓</button>
                </form>
            </div>
            
            <div class="text-center mt-16">
                <a href="/projects/new/group/<%= project_id %>" class="back-link">&larr; Back to Students</a>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>